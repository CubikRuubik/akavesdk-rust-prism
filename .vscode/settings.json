{
  "rust-analyzer.linkedProjects": ["./Cargo.toml"],
  "rust-analyzer.diagnostics.disabled": ["inactive-code"],
  // bottom line helps setting rust-analyzer to analyze code using correct targets.
  // This cfg should be switched depending on which targets we are developing against
  // It should be removed or commented whenever we are developing against non-wasm targets.
  "rust-analyzer.cargo.target": "wasm32-unknown-unknown"
}
