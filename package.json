{
  "name": "akave-rs",
  "type": "module",
  "collaborators": [
    "Gilberto Conde <gilberto.conde@lightshift.xyz>",
    "Sam Hassan <sam.hassan@lightshift.xyz>"
  ],
  "version": "0.8",
  "scripts": {
    "build:web": "wasm-pack build . --target web",
    "build:native": "cargo build --release",
    "build:all": "cargo build --release && wasm-pack build . --target web",
    "test:web": "wasm-pack test --headless --firefox",
    "test:native": "cargo test -- --nocapture",
    "publish:web": "wasm-pack publish",
    "example:web": "npm run build:web && (cd examples/web-demo && npm install && npm start)"
  }
}
